{
  "name": "codenova-ide",
  "version": "2.0.0",
  "description": "CodeNova IDE - VS Code-style Desktop Editor",
  "main": "main.js",
  "author": "CodeNova Team",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "rebuild-pty": "electron-rebuild -f -w node-pty",
    "build:collab": "esbuild collab/client.js --bundle --format=iife --target=es2020 --outfile=collab/dist/client.bundle.js",
    "dist": "npm run build:collab && electron-builder --win",
    "dist:dir": "npm run build:collab && electron-builder --win --dir"
  },
  "build": {
    "appId": "com.codenova.ide",
    "productName": "CodeNova IDE",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!.vs/**"
    ],
    "extraResources": [
      {
        "from": "../java_refactoring_engine/dist",
        "to": "backend-bin",
        "filter": [
          "codenova-backend*"
        ]
      },
      {
        "from": "../java_refactoring_engine",
        "to": "java_refactoring_engine",
        "filter": [
          "**/*.py",
          "**/*.html",
          "**/*.css",
          "**/*.js",
          "__init__.py",
          ".env",
          "!__pycache__/**",
          "!*.pyc",
          "!.env.example",
          "!.venv/**",
          "!build/**",
          "!dist/**"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "CodeNova Team"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CodeNova IDE",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "portable": {
      "artifactName": "CodeNova-IDE-Portable-${version}.exe"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.21.5"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.36",
    "monaco-editor": "^0.45.0",
    "node-pty": "^1.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "yjs": "^13.6.15",
    "y-monaco": "^0.1.5",
    "y-websocket": "^2.0.3",
    "y-protocols": "^1.0.6"
  }
}
