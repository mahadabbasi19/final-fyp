# ============================================================
# CodeNova AI — Apache/cPanel config
# Clean URLs + HTTPS enforcement + security headers
# ============================================================

RewriteEngine On

# --- Force HTTPS (redirect http:// → https://) ---
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- Hide .html: show /products instead of /products.html ---
# If a request for /foo has a matching foo.html, serve it internally.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^([^.]+)$ $1.html [L]

# --- Redirect ugly URLs to clean ones (301, so the bar shows the clean form) ---
# /index.html  →  /
RewriteCond %{THE_REQUEST} \s/index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [L,R=301]
# /anything.html  →  /anything
RewriteCond %{THE_REQUEST} \s/([^.]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [L,R=301]

# --- Default document ---
DirectoryIndex index.html

# ============================================================
# Security headers
# ============================================================
<IfModule mod_headers.c>
  # Stop the site being framed by other domains (clickjacking).
  Header always set X-Frame-Options "SAMEORIGIN"
  # Block MIME-type sniffing.
  Header always set X-Content-Type-Options "nosniff"
  # Control referrer leakage.
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # Restrict powerful browser features.
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # Force HTTPS for a year (only enable once HTTPS is confirmed working).
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ============================================================
# Performance: cache static assets, gzip text
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css            "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/png           "access plus 30 days"
  ExpiresByType image/x-icon        "access plus 30 days"
  # HTML should revalidate so content updates show quickly.
  ExpiresByType text/html           "access plus 0 seconds"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>

# Block access to dotfiles (.htaccess, .git, etc.)
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
